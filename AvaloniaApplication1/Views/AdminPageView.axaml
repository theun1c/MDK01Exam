<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication1.Views.AdminPageView"
             xmlns:vm="clr-namespace:AvaloniaApplication1.ViewModels"
             x:DataType="vm:AdminPageViewModel">
    <StackPanel>
        <Button Content="Logout" Command="{Binding GoBack}"/>
        <Button Content="Create" Command="{Binding CreateUser}"/>
        <Button Content="SortDest" Command="{Binding SortDest}"/>
        <Button Content="SortAsc" Command="{Binding SortAsc}"/>
        <TextBox Text="{Binding Search}"/>
        <ListBox ItemsSource="{Binding Employees}" HorizontalAlignment="Center" Background="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding FirstName}"/>
                        <TextBlock Text="{Binding LastName}"/>
                        <TextBlock Text="{Binding MiddleName}"/>
                        <TextBlock Text="{Binding Role.Name}"/>
                        <TextBlock Text="{Binding Position.Name}"/>
                        <TextBlock Text="{Binding Weight}"/>
                    
                        <Button Content="Edit" Command="{Binding $parent[ListBox].((vm:AdminPageViewModel)DataContext).EditUser}" CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
    
</UserControl>
